# Copy to .env and fill in values. Never commit .env.

# Command Zero
C0_API_BASE_URL=https://api.cmdzero.io/public/v1
C0_ORG_ID=your-org-id-here
C0_BEARER_TOKEN=your-bearer-token-here

# Splunk REST API (defaults shown)
SPLUNK_REST_URL=https://localhost:8089
SPLUNK_SVC_TOKEN=your-splunk-token-here

# REST endpoint of the ES search head, used for the notable_update writeback.
# Leave blank when ES runs on the same search head as SPLUNK_REST_URL (single
# instance). Set it when ES has its own search head — common on Splunk Cloud.
# Ignored when SPLUNK_ES_WRITEBACK=false.
SPLUNK_ES_REST_URL=

# Splunk HEC (optional — leave blank to disable enrichment index writeback)
SPLUNK_HEC_URL=https://localhost:8088
SPLUNK_HEC_TOKEN=your-hec-token-here

# Verify Splunk's TLS certificate. Keep true in production. Set to false ONLY for a
# local self-signed cert — doing so exposes the token and data to MITM.
SPLUNK_VERIFY_TLS=true

# Index names (defaults shown)
NOTABLE_INDEX=notable
ENRICHMENT_INDEX=c0_enrichment

# Poll intervals in seconds (defaults shown)
SPLUNK_POLL_INTERVAL=300
POLL_WINDOW_OVERLAP=600
C0_POLL_INTERVAL=300
C0_POLL_MAX_BACKOFF=1800

# Pause between consecutive C0 submissions, in seconds (accepts fractional values, e.g. 0.5)
C0_SUBMIT_DELAY=2

# Behaviour
ALERT_TYPE_PREFIX=SplunkES
AUTO_DISPOSITION=false

# State DB path (relative to working directory)
DB_PATH=connector.db
